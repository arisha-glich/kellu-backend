generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

generator zod {
  provider = "prisma-zod-generator"
  output   = "../src/zod"
  config   = "../zod.config.json"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                    String           @id @default(cuid())
  name                  String
  email                 String           @unique
  password              String?
  emailVerified         Boolean          @default(false)
  image                 String?
  banned                Boolean          @default(false)
  banReason             String?
  banExpiresAt          DateTime?
  dob                   DateTime?
  gender                String?
  phone_no              String?
  rut                   String?
  onboarding_stage      String?
  createdAt             DateTime         @default(now())
  updatedAt             DateTime         @updatedAt
  role                  UserRole         @default(BUSINESS_OWNER)
  isActive              Boolean          @default(true)
  lastLoginAt           DateTime?
  isOwner               Boolean          @default(false)
  /// True when the user was invited via the admin portal team API (session exposes SUPER_ADMIN + isAdmin false; DB role stays BUSINESS_OWNER).
  adminPortalTeamMember Boolean          @default(false)
  auditLogs             AuditLog[]
  businessesOwned       Business[]       @relation("BusinessOwner")
  teamMemberships       Member[]         @relation("TeamMember")
  notifications         Notification[]
  teamInvitationsSent   TeamInvitation[] @relation("InvitedBy")
  accounts              Account[]
  sessions              Session[]
}

model Business {
  id              String            @id @default(cuid())
  name            String
  legalName       String?
  email           String
  phone           String?
  address         String?
  webpage         String?
  logoUrl         String?
  isActive        Boolean           @default(true)
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  ownerId         String?
  countyId        String?
  state           String?
  zipcode         String?
  rutNumber       String?
  city            String?
  primaryColor    String?
  secondaryColor  String?
  street1         String?
  street2         String?
  /// IANA timezone from browser/locale (e.g. America/Edmonton); scheduling & reminders
  timeZone        String            @default("UTC") @map("timezone")
  /// ISO 3166-1 alpha-2 (e.g. US, CA, GB); from locale; phone/format requirements
  country         String?
  auditLogs       AuditLog[]
  owner           User?             @relation("BusinessOwner", fields: [ownerId], references: [id])
  settings        BusinessSettings?
  clients         Client[]
  expenses        Expense[]
  invoices        Invoice[]
  teamMembers     Member[]
  priceListItems  PriceListItem[]
  quotes          Quote[]
  reminderConfigs ReminderConfig[]
  reminderLogs    ReminderLog[]
  roles           Role[]
  tasks           Task[]
  teamInvitations TeamInvitation[]
  workOrders      WorkOrder[]
}

model Member {
  id                                 String                @id @default(cuid())
  isActive                           Boolean               @default(true)
  createdAt                          DateTime              @default(now())
  updatedAt                          DateTime              @updatedAt
  userId                             String
  businessId                         String
  roleId                             String
  includeInNotificationsWhenAssigned Boolean               @default(true)
  calendarColor                      String?
  assignedInvoices                   Invoice[]
  business                           Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  role                               Role                  @relation(fields: [roleId], references: [id])
  user                               User                  @relation("TeamMember", fields: [userId], references: [id], onDelete: Cascade)
  assignedQuotes                     Quote[]               @relation("QuoteAssignee")
  assignedTasks                      Task[]                @relation("TaskAssignee")
  taskAssignments                    TaskAssignment[]
  primaryAssignedWorkOrders          WorkOrder[]           @relation("WorkOrderPrimaryAssignee")
  workOrderAssignments               WorkOrderAssignment[]

  @@unique([userId, businessId])
  @@map("Member")
}

model TeamInvitation {
  id          String   @id @default(cuid())
  email       String
  token       String   @unique
  status      String   @default("pending")
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  businessId  String
  roleId      String
  invitedById String?
  business    Business @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invitedBy   User?    @relation("InvitedBy", fields: [invitedById], references: [id])
  role        Role     @relation(fields: [roleId], references: [id])
}

model Role {
  id              String           @id @default(cuid())
  name            String
  displayName     String?
  description     String?
  isSystem        Boolean          @default(false)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  businessId      String
  portalScope     RolePortalScope  @default(BUSINESS_PORTAL)
  members         Member[]
  business        Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  permissions     RolePermission[]
  teamInvitations TeamInvitation[]

  @@unique([businessId, name, portalScope])
}

model Permission {
  id                   String           @id @default(cuid())
  resource             String
  action               String
  description          String?
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt
  /// UI grouping for admin “Roles & Permissions” matrix (e.g. Jobs, Invoices).
  section              String?
  /// If true, business-created custom roles cannot include this permission (platform governance).
  lockedForCustomRoles Boolean          @default(false)
  roles                RolePermission[]

  @@unique([resource, action])
  @@index([resource])
  @@map("permission")
}

model RolePermission {
  createdAt    DateTime   @default(now())
  roleId       String
  permissionId String
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
}

model Client {
  id             String        @id @default(cuid())
  name           String
  email          String?
  phone          String
  address        String?
  documentNumber String?
  leadSource     LeadSource    @default(Website)
  notes          String?
  status         ClientStatus  @default(ACTIVE)
  lastActivityAt DateTime?
  reminderDate   DateTime?
  reminderNote   String?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  businessId     String
  business       Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  invoices       Invoice[]
  quotes         Quote[]
  reminderLogs   ReminderLog[]
  tasks          Task[]
  workOrders     WorkOrder[]
}

model WorkOrder {
  id                         String                @id @default(cuid())
  workOrderNumber            String?
  title                      String
  address                    String
  instructions               String?
  notes                      String?
  createdAt                  DateTime              @default(now())
  updatedAt                  DateTime              @updatedAt
  isScheduleLater            Boolean               @default(false)
  isAnyTime                  Boolean               @default(false)
  scheduledAt                DateTime?
  startTime                  String?
  endTime                    String?
  clientId                   String
  businessId                 String
  primaryAssigneeId          String?               @map("assignedToId")
  jobStatus                  JobStatus             @default(UNSCHEDULED)
  bookingConfirmationSentAt  DateTime?
  confirmedAt                DateTime?
  onMyWayAt                  DateTime?
  startedAt                  DateTime?
  completedAt                DateTime?
  cancelledAt                DateTime?
  invoiceStatus              InvoiceStatus         @default(NOT_SENT)
  invoiceSentAt              DateTime?
  dueAt                      DateTime?
  invoiceCancelledAt         DateTime?
  badDebtAt                  DateTime?
  lastInvoicePdfUrl          String?
  invoiceCorrelative         String?
  invoiceWhatsappStatus      String?
  invoiceObservations        String?
  invoiceTermsConditions     String?
  subtotal                   Decimal?              @db.Decimal(12, 2)
  discount                   Decimal?              @db.Decimal(12, 2)
  discountType               DiscountType?
  tax                        Decimal?              @db.Decimal(12, 2)
  total                      Decimal?              @db.Decimal(12, 2)
  cost                       Decimal?              @db.Decimal(12, 2)
  amountPaid                 Decimal?              @default(0) @db.Decimal(12, 2)
  balance                    Decimal?              @db.Decimal(12, 2)
  lastJobReportPdfUrl        String?
  confirmationReminderSentAt DateTime?
  quoteTermsConditions       String?
  expenses                   Expense[]
  invoices                   Invoice[]
  lineItems                  LineItem[]
  payments                   Payment[]
  quotes                     Quote[]
  reminderLogs               ReminderLog[]
  linkedTasks                Task[]
  primaryAssignee            Member?               @relation("WorkOrderPrimaryAssignee", fields: [primaryAssigneeId], references: [id])
  business                   Business              @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client                     Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  assignees                  WorkOrderAssignment[]
  attachments                WorkOrderAttachment[]

  @@unique([businessId, workOrderNumber])
}

model WorkOrderAssignment {
  id          String    @id @default(cuid())
  workOrderId String
  memberId    String
  createdAt   DateTime  @default(now())
  member      Member    @relation(fields: [memberId], references: [id], onDelete: Cascade)
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@unique([workOrderId, memberId])
  @@index([memberId])
}

model Quote {
  id                         String            @id @default(cuid())
  quoteNumber                String?
  title                      String
  address                    String
  instructions               String?
  notes                      String?
  createdAt                  DateTime          @default(now())
  updatedAt                  DateTime          @updatedAt
  isScheduleLater            Boolean           @default(true)
  isAnyTime                  Boolean           @default(false)
  scheduledAt                DateTime?
  startTime                  String?
  endTime                    String?
  clientId                   String
  businessId                 String
  assignedToId               String?
  quoteStatus                QuoteStatus       @default(NOT_APPLIED)
  quoteSentAt                DateTime?
  quoteApprovedAt            DateTime?
  quoteRejectedAt            DateTime?
  quoteExpiredAt             DateTime?
  quoteConvertedAt           DateTime?
  quoteExpiresAt             DateTime?
  lastQuotePdfUrl            String?
  quoteCorrelative           String?
  quoteClientActionToken     String?
  quoteClientRespondedAt     DateTime?
  quoteClientRejectionReason String?
  quoteWhatsappStatus        String?
  quoteObservations          String?
  quoteTermsConditions       String?
  quoteVersion               Int               @default(1)
  subtotal                   Decimal?          @db.Decimal(12, 2)
  discount                   Decimal?          @db.Decimal(12, 2)
  discountType               DiscountType?
  tax                        Decimal?          @db.Decimal(12, 2)
  total                      Decimal?          @db.Decimal(12, 2)
  cost                       Decimal?          @db.Decimal(12, 2)
  amountPaid                 Decimal?          @default(0) @db.Decimal(12, 2)
  balance                    Decimal?          @db.Decimal(12, 2)
  lastJobReportPdfUrl        String?
  quoteRequired              Boolean           @default(false)
  workOrderId                String?
  lineItems                  LineItem[]
  assignedTo                 Member?           @relation("QuoteAssignee", fields: [assignedToId], references: [id])
  business                   Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client                     Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workOrder                  WorkOrder?        @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  attachments                QuoteAttachment[]

  @@unique([businessId, quoteNumber])
}

model QuoteAttachment {
  id        String   @id @default(cuid())
  url       String
  filename  String?
  type      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  quoteId   String
  quote     Quote    @relation(fields: [quoteId], references: [id], onDelete: Cascade)

  @@index([quoteId])
}

model Invoice {
  id              String        @id @default(cuid())
  invoiceNumber   String?
  title           String
  address         String?
  status          InvoiceStatus @default(NOT_SENT)
  sentAt          DateTime?
  dueAt           DateTime?
  cancelledAt     DateTime?
  badDebtAt       DateTime?
  subtotal        Decimal?      @db.Decimal(12, 2)
  discount        Decimal?      @db.Decimal(12, 2)
  discountType    DiscountType?
  tax             Decimal?      @db.Decimal(12, 2)
  total           Decimal?      @db.Decimal(12, 2)
  amountPaid      Decimal?      @default(0) @db.Decimal(12, 2)
  balance         Decimal?      @db.Decimal(12, 2)
  whatsappStatus  String?
  observations    String?
  termsConditions String?
  pdfUrl          String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  clientId        String
  businessId      String
  workOrderId     String?
  assignedToId    String?
  version         Int           @default(1)
  invoiceRequired Boolean       @default(false)
  assignedTo      Member?       @relation(fields: [assignedToId], references: [id])
  business        Business      @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder?    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
  lineItems       LineItem[]
  payments        Payment[]

  @@unique([businessId, invoiceNumber])
}

model Payment {
  id              String        @id @default(cuid())
  amount          Decimal       @db.Decimal(12, 2)
  paymentDate     DateTime      @db.Date
  paymentMethod   PaymentMethod
  referenceNumber String?
  note            String?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  workOrderId     String?
  invoiceId       String?
  invoice         Invoice?      @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder?    @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([invoiceId])
}

model LineItem {
  id              String         @id @default(cuid())
  name            String
  itemType        ItemType       @default(SERVICE)
  description     String?
  quantity        Int            @default(1)
  cost            Decimal?       @db.Decimal(12, 2)
  markupPercent   Decimal?       @db.Decimal(5, 2)
  price           Decimal        @db.Decimal(12, 2)
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  workOrderId     String?
  priceListItemId String?
  invoiceId       String?
  quoteId         String?
  invoice         Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  priceListItem   PriceListItem? @relation(fields: [priceListItemId], references: [id])
  quote           Quote?         @relation(fields: [quoteId], references: [id], onDelete: Cascade)
  workOrder       WorkOrder?     @relation(fields: [workOrderId], references: [id], onDelete: Cascade)

  @@index([workOrderId])
  @@index([invoiceId])
  @@index([quoteId])
  @@index([priceListItemId])
}

model WorkOrderAttachment {
  id          String    @id @default(cuid())
  url         String
  filename    String?
  type        String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  workOrderId String
  workOrder   WorkOrder @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model Task {
  id           String           @id @default(cuid())
  title        String
  address      String?
  instructions String?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt
  scheduledAt  DateTime?
  startTime    String?
  endTime      String?
  clientId     String?
  businessId   String
  workOrderId  String?
  assignedToId String?
  completedAt  DateTime?
  isCompleted  Boolean          @default(false)
  isAnyTime    Boolean          @default(false)
  startedAt    DateTime?
  taskStatus   TaskStatus       @default(SCHEDULED)
  assignedTo   Member?          @relation("TaskAssignee", fields: [assignedToId], references: [id])
  business     Business         @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client       Client?          @relation(fields: [clientId], references: [id])
  workOrder    WorkOrder?       @relation(fields: [workOrderId], references: [id])
  assignees    TaskAssignment[]
}

model TaskAssignment {
  id        String   @id @default(cuid())
  taskId    String
  memberId  String
  createdAt DateTime @default(now())
  member    Member   @relation(fields: [memberId], references: [id], onDelete: Cascade)
  task      Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@unique([taskId, memberId])
  @@index([memberId])
}

model PriceListItem {
  id            String     @id @default(cuid())
  itemType      ItemType   @default(SERVICE)
  name          String
  description   String?
  cost          Decimal?   @db.Decimal(12, 2)
  markupPercent Decimal?   @db.Decimal(5, 2)
  price         Decimal    @db.Decimal(12, 2)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  businessId    String
  lineItems     LineItem[]
  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model Expense {
  id            String     @id @default(cuid())
  date          DateTime   @db.Date
  itemName      String
  details       String?
  total         Decimal    @db.Decimal(12, 2)
  invoiceNumber String?
  attachmentUrl String?
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
  businessId    String
  workOrderId   String?
  business      Business   @relation(fields: [businessId], references: [id], onDelete: Cascade)
  workOrder     WorkOrder? @relation(fields: [workOrderId], references: [id])
}

model BusinessSettings {
  id                             String            @id @default(cuid())
  invoiceDueDays                 Int               @default(3)
  quoteExpirationDays            Int               @default(7)
  arrivalWindowMinutes           Int?
  defaultDurationMinutes         Int?
  bankName                       String?
  accountType                    String?
  accountNumber                  String?
  paymentEmail                   String?
  onlinePaymentLink              String?
  quoteTermsConditions           String?
  invoiceTermsConditions         String?
  whatsappSender                 String?
  whatsappEnabled                Boolean           @default(false)
  sendQuoteWhatsappDefault       Boolean           @default(false)
  notificationEmail              String?
  replyToEmail                   String?
  sendTeamPhotosWithConfirmation Boolean           @default(false)
  quoteRemindersEnabled          Boolean           @default(true)
  bookingRemindersEnabled        Boolean           @default(true)
  invoiceRemindersEnabled        Boolean           @default(true)
  createdAt                      DateTime          @default(now())
  updatedAt                      DateTime          @updatedAt
  businessId                     String            @unique
  defaultTaxRate                 Decimal?          @db.Decimal(5, 2)
  rutNumber                      String?
  arrivalWindowHours             Int?
  business                       Business          @relation(fields: [businessId], references: [id], onDelete: Cascade)
  templates                      MessageTemplate[]
}

model MessageTemplate {
  id           String              @id @default(cuid())
  templateType TemplateType
  channel      NotificationChannel @default(EMAIL)
  subject      String?
  message      String
  isDefault    Boolean             @default(false)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  settingsId   String
  settings     BusinessSettings    @relation(fields: [settingsId], references: [id], onDelete: Cascade)
}

model ReminderConfig {
  id           String              @id @default(cuid())
  reminderType ReminderType
  timeValue    Int
  timeUnit     String
  timeOfDay    String?
  channel      NotificationChannel @default(EMAIL)
  subject      String?
  message      String?
  isEnabled    Boolean             @default(true)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  businessId   String
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
}

model ReminderLog {
  id           String              @id @default(cuid())
  reminderType String
  sentAt       DateTime
  channel      NotificationChannel
  entityType   String
  entityId     String
  clientId     String?
  businessId   String
  createdAt    DateTime            @default(now())
  workOrderId  String?
  note         String?
  business     Business            @relation(fields: [businessId], references: [id], onDelete: Cascade)
  client       Client?             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workOrder    WorkOrder?          @relation(fields: [workOrderId], references: [id], onDelete: Cascade)
}

model Notification {
  id        String    @id @default(cuid())
  type      String
  title     String
  message   String?
  readAt    DateTime?
  metadata  Json?
  createdAt DateTime  @default(now())
  userId    String
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model AuditLog {
  id         String    @id @default(cuid())
  action     String
  entityType String
  entityId   String?
  oldValues  Json?
  newValues  Json?
  ipAddress  String?
  userAgent  String?
  createdAt  DateTime  @default(now())
  userId     String?
  businessId String?
  business   Business? @relation(fields: [businessId], references: [id])
  user       User?     @relation(fields: [userId], references: [id])
}

model Session {
  id        String   @id @default(cuid())
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("session")
}

model Account {
  id                    String    @id @default(cuid())
  userId                String
  accountId             String
  providerId            String
  accessToken           String?
  refreshToken          String?
  accessTokenExpiresAt  DateTime?
  refreshTokenExpiresAt DateTime?
  scope                 String?
  idToken               String?
  password              String?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt
  user                  User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("account")
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  @@index([identifier])
  @@map("verification")
}

model PlatformSettings {
  id                     String   @id @default(cuid())
  platformLogoUrl        String?
  platformName           String?
  primaryColor           String?
  domain                 String?
  supportEmail           String?
  defaultQuoteTerms      String?
  defaultInvoiceTerms    String?
  /// When true, BCC platform copy address on business → customer emails (e.g. quote to client).
  clientEmailCopyEnabled Boolean  @default(false)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  /// BCC destination for client-facing emails sent by businesses (admin-configured).
  clientEmailCopyTo      String?
}

model PlatformNotificationRule {
  id                 String   @id @default(cuid())
  /// Stable key for code (e.g. QUOTE_REJECTED_BY_CLIENT, JOB_COMPLETED).
  eventKey           String   @unique
  eventName          String
  triggerDescription String
  isActive           Boolean  @default(true)
  sortOrder          Int      @default(0)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
}

enum UserRole {
  SUPER_ADMIN
  BUSINESS_OWNER
}

enum ClientStatus {
  ACTIVE
  ARCHIVED
  FOLLOW_UP
}

enum QuoteStatus {
  NOT_APPLIED
  AWAITING_RESPONSE
  APPROVED
  CONVERTED
  REJECTED
  EXPIRED
}

enum JobStatus {
  UNSCHEDULED
  SCHEDULED
  NOT_APPLIED

}

enum InvoiceStatus {
  NOT_SENT
  AWAITING_PAYMENT
  OVERDUE
  PAID
  BAD_DEBT
  CANCELLED
}

enum DiscountType {
  PERCENTAGE
  AMOUNT
}

enum PaymentMethod {
  CASH
  CARD
  TRANSFER
  MERCADOPAGO
  TRANSBANK
  OTHER
}

enum ItemType {
  SERVICE
  PRODUCT
}

enum ReminderType {
  QUOTE_FOLLOW_UP_48H
  QUOTE_FOLLOW_UP_120H
  BOOKING_CONFIRMATION
  INVOICE_DUE_DAY
  INVOICE_OVERDUE_2DAYS
  CLIENT_FOLLOW_UP
}

enum NotificationChannel {
  EMAIL
  WHATSAPP
  BOTH
}

enum TemplateType {
  QUOTE
  QUOTE_FOLLOW_UP
  INVOICE
  INVOICE_FOLLOW_UP
  BOOKING_CONFIRMATION
  BOOKING_CONFIRMATION_REMINDER
  JOB_REPORT
}

enum LeadSource {
  Website
  SocialMedia
  Referral
  Other
}

enum TaskStatus {
  SCHEDULED
  IN_PROGRESS
  COMPLETED
  UNSCHEDULED
  CANCELLED
}

/// Roles created from the business app vs admin portal (same tenant, isolated lists).
enum RolePortalScope {
  BUSINESS_PORTAL
  ADMIN_PORTAL
}
